# Bit-Bite Backend Configuration

# Flask
SECRET_KEY=your-secret-key-here
PORT=5001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bitbite

# LNbits Configuration
LNBITS_URL=http://localhost:3000
LNBITS_ADMIN_KEY=your-admin-key
LNBITS_INVOICE_KEY=your-invoice-key
LNBITS_WEBHOOK_SECRET=change-me

# Fees (in satoshis)
PLATFORM_FEE_SATS=10
DELIVERY_FEE_SATS=50

# Local frontend
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
